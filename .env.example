# StockBoard 環境変数テンプレート
# このファイルをコピーして .env.local を作成し、各値を実値に置き換える。
# .env.local は .gitignore 済み (リポジトリに上がらない)。

# ─── J-Quants API (Phase 3.5 以降の唯一のデータソース) ───
# Premium プラン契約のダッシュボードで発行する API キー。
# v2 仕様、有効期限なし (再発行可能)。
JQUANTS_API_KEY=eyJxxx_paste_v2_api_key_here

# ─── Turso (libSQL クラウド DB) ───
# 既存の web app (capital-flow / screener など) が読む既存テーブル用。
# 新しい Phase 2 以降のテーブル (ohlcv_daily / daily_snapshots / feature_snapshots
# / forward_returns / pattern_stats / stage_transitions) はローカル SQLite を使う。
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=eyJxxx_paste_turso_token_here

# ─── オプション: バッチスクリプトで Turso を無視してローカル DB を強制 ───
# USE_LOCAL_DB=1 を設定すると lib/db/client.ts がローカル file:./data/stockboard.db を選ぶ。
# Turso のクォータ超過時や、新規 Phase 2+ テーブルがローカルにしかない時に使う。
# USE_LOCAL_DB=1
