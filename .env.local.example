# Turso (libSQL) credentials
# Get these from https://app.turso.tech or via the Turso CLI:
#   turso db show <db-name> --url
#   turso db tokens create <db-name>
TURSO_DATABASE_URL=libsql://<your-db>-<your-org>.turso.io
TURSO_AUTH_TOKEN=

# For local-only development you can use an embedded file instead:
# TURSO_DATABASE_URL=file:./data/stockboard.db
# TURSO_AUTH_TOKEN=
